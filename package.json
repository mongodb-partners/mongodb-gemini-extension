{
  "name": "mongodb-gemini-extension",
  "version": "2.0.0",
  "description": "A Gemini CLI extension for MongoDB — thin wrapper around the official mongodb-mcp-server npm package, providing all MongoDB database and Atlas operations through the Gemini CLI.",
  "type": "module",
  "scripts": {
    "start": "node run.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mongodb-mcp-server": "^1.8.0"
  },
  "devDependencies": {
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=23.0.0"
  },
  "keywords": [
    "gemini",
    "gemini-cli",
    "extension",
    "mcp",
    "mcp-server",
    "mongodb",
    "mongodb-atlas"
  ],
  "author": "MongoDB",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohammaddaoudfarooqi/mongodb-gemini-extension.git"
  },
  "homepage": "https://github.com/mohammaddaoudfarooqi/mongodb-gemini-extension",
  "bugs": {
    "url": "https://github.com/mohammaddaoudfarooqi/mongodb-gemini-extension/issues"
  }
}
